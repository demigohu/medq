# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
**/coverage

# next.js (root + all apps)
.next/
**/.next/
/out/
**/out/

# production
/build
**/build

# misc
.DS_Store
*.pem
*.log
*.Zone.Identifier

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local
apps/api/.env
apps/api/.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
apps/api/*.tsbuildinfo

# Backend specific
apps/api/dist/
apps/api/.env.local

# Foundry / Smart Contracts
# Keep lib/ folder but ignore all its contents
/contracts/lib/*
!/contracts/lib/.gitkeep
/contracts/lib/**/.github/
/contracts/lib/**/.github/*
/contracts/lib/**/.gitignore
/contracts/lib/**/.gitattributes
/contracts/cache/
/contracts/broadcast/*/31337/
/contracts/broadcast/**/dry-run/
/contracts/.env
/contracts/.env.local

# Keep broadcast for deployment logs (but ignore local dev chains)
!/contracts/broadcast
!/contracts/broadcast/**/296/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store
