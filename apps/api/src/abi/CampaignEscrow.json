puts\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"rewardToken\",\"outputs\":[{\"internalType\":\"contract IERC20\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"releaser_\",\"type\":\"address\"}],\"name\":\"setRewardReleaser\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"tokenAddress\",\"type\":\"address\"}],\"name\":\"setRewardToken\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"newOwner\",\"type\":\"address\"}],\"name\":\"transferOwnership\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"errors\":{\"OwnableInvalidOwner(address)\":[{\"details\":\"The owner is not a valid owner account. (eg. `address(0)`)\"}],\"OwnableUnauthorizedAccount(address)\":[{\"details\":\"The caller account is not authorized to perform an operation.\"}],\"SafeERC20FailedOperation(address)\":[{\"details\":\"An operation with an ERC-20 token failed.\"}]},\"kind\":\"dev\",\"methods\":{\"deposit(bytes32,uint256)\":{\"params\":{\"amount\":\"Token amount (with token decimals)\",\"campaignId\":\"bytes32 - keccak256(abi.encodePacked(campaignUuid)) from backend\"}},\"owner()\":{\"details\":\"Returns the address of the current owner.\"},\"releaseReward(bytes32,address,uint256)\":{\"params\":{\"amount\":\"Token amount to release\",\"campaignId\":\"bytes32 - must match the campaign UUID hash used in deposit\",\"recipient\":\"Participant who completed the quest\"}},\"renounceOwnership()\":{\"details\":\"Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner.\"},\"transferOwnership(address)\":{\"details\":\"Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner.\"}},\"stateVariables\":{\"HTS_PRECOMPILE\":{\"details\":\"Hedera HTS precompile (HIP-206)\"},\"HTS_SUCCESS\":{\"details\":\"HederaResponseCodes.SUCCESS\"},\"HTS_TOKEN_ALREADY_ASSOCIATED\":{\"details\":\"HederaResponseCodes.TOKEN_ALREADY_ASSOCIATED_TO_ACCOUNT\"}},\"title\":\"CampaignEscrow\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"deposit(bytes32,uint256)\":{\"notice\":\"Partner deposits tokens for a campaign.\"},\"releaseReward(bytes32,address,uint256)\":{\"notice\":\"Release reward to quest completer. Called by backend oracle.\"},\"rewardReleaser()\":{\"notice\":\"Authorized address that can release rewards (backend oracle)\"},\"rewardToken()\":{\"notice\":\"Token used for campaign rewards (e.g. USDC)\"}},\"notice\":\"Holds partner-funded token rewards (e.g. USDC) for campaign quest completions.         Partner deposits, oracle releases to participants on quest completion.         On Hedera: HTS tokens (e.g. USDC) require token association before receive.         This contract auto-associates on setRewardToken. Participants must associate         the reward token with their account before receiving rewards.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/CampaignEscrow.sol\":\"CampaignEscrow\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@hashgraph/=lib/hedera-smart-contracts/\",\":@openzeppelin/=lib/openzeppelin-contracts/\",\":ds-test/=lib/hedera-smart-contracts/lib/forge-std/lib/ds-test/src/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":hardhat/=lib/hedera-smart-contract